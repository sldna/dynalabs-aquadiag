BACKEND_PORT=8080
FRONTEND_PORT=3000
DATABASE_PATH=/data/aquadiag.db

# "development" (default) shows extra debug metadata; set to "production" to hide it.
APP_ENV=development

AI_ENABLED=false
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_TIMEOUT_SECONDS=8

# Optional: Pfad zur YAML-Regeldatei. Ohne RULES_PATH: automatisch rules/aquarium-rules.yaml (CWD = Repo-Root)
# oder ../rules/aquarium-rules.yaml (CWD = backend/). Im offiziellen Image: /app/rules/aquarium-rules.yaml (Compose-Build nutzt Repo-Root als context).
# RULES_PATH=/app/rules/aquarium-rules.yaml
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Im Browser erreichbare API (lokal: Host-Port; in Docker Compose: Host-Port des Backends)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional: API-URL für Server-seitige Requests (Next.js RSC). In Compose per Default http://backend:8080.
# API_INTERNAL_BASE_URL=http://backend:8080
