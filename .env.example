# =============================================================================
# AquaDiag – Beispielkonfiguration
# Kopiere diese Datei: `cp .env.example .env` und passe Werte bei Bedarf an.
# Mit den Defaults läuft AquaDiag lokal ohne weitere Konfiguration.
# =============================================================================

# --- Anwendung ---------------------------------------------------------------
# "development" zeigt zusätzliche Debug-Metadaten; "production" versteckt sie.
APP_ENV=development

# --- Ports -------------------------------------------------------------------
BACKEND_PORT=8080
FRONTEND_PORT=3000

# --- Datenbank ---------------------------------------------------------------
# Pfad innerhalb des Backend-Containers (Volume `aquadiag-data` -> /data).
# Außerhalb von Docker: relativen oder absoluten Pfad setzen, z.B. ./aquadiag.db
DATABASE_PATH=/data/aquadiag.db

# --- Regel-Engine ------------------------------------------------------------
# Optional. Ohne Angabe: rules/aquarium-rules.yaml (Repo-Root) bzw.
# /app/rules/aquarium-rules.yaml im Container-Image.
# RULES_PATH=/app/rules/aquarium-rules.yaml

# --- AI / Explainability Layer (optional) ------------------------------------
# AquaDiag funktioniert vollständig OHNE AI. Die Diagnose stammt immer aus der
# YAML-Regel-Engine; AI dient ausschließlich als Erklärungsschicht.
# Solange AI_ENABLED=false bleibt, werden keine externen Requests gemacht.
AI_ENABLED=false
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_TIMEOUT_SECONDS=8

# --- API / CORS --------------------------------------------------------------
# Erlaubte Browser-Origins (durch Komma trennen). In Compose automatisch
# abgeleitet von FRONTEND_PORT, falls nicht gesetzt.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Browser-seitige API-Basis-URL (Host-Port-Mapping in Compose).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional: Server-seitige Basis-URL für Next.js (RSC). In Compose Default
# http://backend:8080 – darüber bleibt der Browser CORS-frei.
# API_INTERNAL_BASE_URL=http://backend:8080

# Optional: schaltet eine eingebaute Mock-Antwort für /v1/diagnose im Frontend
# ein (UI-Entwicklung ohne Backend). 1 = aktiv, leer/0 = aus.
# NEXT_PUBLIC_DIAGNOSE_MOCK=
