# Synology / GHCR – Beispielkonfiguration
# Kopieren: cp .env.synology.example .env.synology
# IP oder Hostname der Synology anpassen, dann:
#   docker compose --env-file .env.synology -f docker-compose.synology.yml up -d

BACKEND_PORT=8080
FRONTEND_PORT=3000

# Browser-Anzeige / Fallback (siehe README: Build-Zeit-Hinweis)
NEXT_PUBLIC_API_BASE_URL=http://DEINE-SYNOLOGY-IP:8080

# Erlaubte Browser-Origin (Frontend-URL)
CORS_ALLOWED_ORIGINS=http://DEINE-SYNOLOGY-IP:3000

# Optional: AI-Erklärungsschicht (AquaDiag funktioniert ohne AI)
AI_ENABLED=false
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_TIMEOUT_SECONDS=8
